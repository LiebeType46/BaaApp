<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:text="カテゴリ"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/spSearchCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingBottom="4dp"
            android:text="サブカテゴリ"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etSearchSubCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="サブカテゴリ"
            android:inputType="text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingBottom="4dp"
            android:text="開始日時"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvSearchFrom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/edit_text"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:hint="未指定"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingBottom="4dp"
            android:text="終了日時"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvSearchTo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/edit_text"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            android:hint="未指定"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingBottom="4dp"
            android:text="メモキーワード"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etSearchKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="キーワード"
            android:inputType="text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingBottom="4dp"
            android:text="半径（m）"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etSearchRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="未指定"
            android:inputType="numberDecimal" />

        <CheckBox
            android:id="@+id/cbHasPhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="写真ありのみ" />

        <CheckBox
            android:id="@+id/cbUnsentOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未送信のみ" />

    </LinearLayout>
</ScrollView>
